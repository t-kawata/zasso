{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zasso",
  "version": "0.24.249",
  "identifier": "com.t-kawata.zasso",
  "build": {
    "beforeDevCommand": "cd ../fe && pnpm dev",
    "beforeBuildCommand": "cd ../fe && pnpm build",
    "devUrl": "http://localhost:7654",
    "frontendDist": "../fe/dist/spa"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "zasso",
        "width": 160,
        "height": 185,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "acceptFirstMouse": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
